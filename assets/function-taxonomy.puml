skinparam shadowing false

<style>
mindmapDiagram {
  .definition {
    BackgroundColor #E3F2FD
    LineColor #1565C0
  }
  .generate {
    BackgroundColor #E8F5E9
    LineColor #2E7D32
  }
  .select {
    BackgroundColor #FFF3E0
    LineColor #E65100
  }
  .mapping {
    BackgroundColor #F3E5F5
    LineColor #6A1B9A
  }
  .fold {
    BackgroundColor #FCE4EC
    LineColor #AD1457
  }
  .concat {
    BackgroundColor #E0F7FA
    LineColor #00695C
  }
